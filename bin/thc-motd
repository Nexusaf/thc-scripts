#!/usr/bin/zsh

# THC-OS: Sistema de Identidade Visual de Login
# Executado automaticamente pelo ~/.zshrc em cada login.

# в”Җв”Җ Paleta de Cores в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
C_CYAN='\e[1;36m'
C_MAGENTA='\e[1;35m'
C_YELLOW='\e[1;33m'
C_GREEN='\e[1;32m'
C_RED='\e[1;31m'
C_WHITE='\e[1;37m'
C_DIM='\e[2;37m'
RESET='\e[0m'
BOLD='\e[1m'

# в”Җв”Җ Limpeza de Tela в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
clear

# в”Җв”Җ Logotipo ASCII в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "${C_CYAN}"
echo "   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
echo "      в–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ     в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ"
echo "      в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘          в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
echo "      в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘          в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘"
echo "      в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—     в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘"
echo "      в•ҡв•җв•қ   в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ      в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қ"
echo -e "${RESET}"
echo -e "${C_DIM}     в–‘в–‘  Operating System вҖ” Identity Core Active  в–‘в–‘${RESET}"
echo ""

# в”Җв”Җ Linha Separadora в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "${C_CYAN}  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${RESET}"

# в”Җв”Җ Coleta de Dados do Sistema в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
THC_USER=$(whoami)
THC_HOST=$(cat /etc/hostname)
THC_KERNEL=$(uname -r)
THC_DATE=$(date '+%d/%m/%Y вҖ” %H:%M')
THC_UPTIME=$(uptime -p | sed 's/up //')
THC_DISK=$(df -h / | awk 'NR==2 {print $3 " / " $2 " (" $5 ")"}')
THC_MEM=$(free -m | awk 'NR==2 {printf "%dMB / %dMB (%.0f%%)", $3, $2, $3/$2*100}')
THC_IP=$(ip -4 addr show | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | grep -v 127 | head -1)
THC_CMDS=$(ls /thc/bin/ 2>/dev/null | wc -l)

# в”Җв”Җ Painel de Identidade в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "${C_CYAN}  в”Ӯ${RESET}  ${C_YELLOW}UsuГЎrio  ${RESET}В» ${C_WHITE}${THC_USER}${C_DIM}@${THC_HOST}${RESET}"
echo -e "${C_CYAN}  в”Ӯ${RESET}  ${C_YELLOW}Data     ${RESET}В» ${C_WHITE}${THC_DATE}${RESET}"
echo -e "${C_CYAN}  в”Ӯ${RESET}  ${C_YELLOW}Kernel   ${RESET}В» ${C_WHITE}${THC_KERNEL}${RESET}"
echo -e "${C_CYAN}  в”Ӯ${RESET}  ${C_YELLOW}Uptime   ${RESET}В» ${C_WHITE}${THC_UPTIME}${RESET}"
echo -e "${C_CYAN}  в”Ӯ${RESET}  ${C_YELLOW}Network  ${RESET}В» ${C_WHITE}${THC_IP:-Sem conexГЈo detectada}${RESET}"
echo -e "${C_CYAN}  в”Ӯ${RESET}  ${C_YELLOW}Disco    ${RESET}В» ${C_WHITE}${THC_DISK}${RESET}"
echo -e "${C_CYAN}  в”Ӯ${RESET}  ${C_YELLOW}MemГіria  ${RESET}В» ${C_WHITE}${THC_MEM}${RESET}"
echo -e "${C_CYAN}  в”Ӯ${RESET}  ${C_YELLOW}Comandos ${RESET}В» ${C_GREEN}${THC_CMDS} comandos THC disponГӯveis${RESET}"
echo -e "${C_CYAN}  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${RESET}"
echo ""
echo -e "  ${C_DIM}Digite ${RESET}${C_GREEN}thc${RESET}${C_DIM} para ver os comandos disponГӯveis.${RESET}"
echo ""
