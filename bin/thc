#!/usr/bin/zsh

# Core THC-OS Hub Command

MAGENTA='\e[1;35m'
CYAN='\e[1;36m'
YELLOW='\e[1;33m'
GREEN='\e[1;32m'
RESET='\e[0m'
BOLD='\e[1m'

echo -e "${CYAN}    _______ __  __ _____ "
echo -e "${CYAN}   /_  __// // / / ___/ "
echo -e "${CYAN}    / /  / __  // /__   "
echo -e "${CYAN}   /_/  /_/ /_/ \___/   ${RESET}"
echo -e "${BOLD}${MAGENTA}   O P E R A T I O N S  ${RESET}"
echo ""
echo -e "${YELLOW} ► THC Core is Active and Responding.${RESET}"
echo ""
echo -e "${BOLD}Available Sub-Commands:${RESET}"
echo -e "  ${GREEN}thc-info${RESET}    : Exibe as especificações profundas do sistema"
echo -e "  ${GREEN}thc-health${RESET}  : Monitora métricas de memória, disco e uptime"
echo -e "  ${GREEN}thc-paths${RESET}   : Mapeia e explica a raiz física /thc/ do SO"
echo ""
echo -e "${CYAN}Usage:${RESET} Digite qualquer um dos subcomandos acima para interagir."
echo ""
