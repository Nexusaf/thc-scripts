#!/usr/bin/zsh

# THC Command: thc-info
# Displays Core System Information

# Cores
MAGENTA='\e[1;35m'
CYAN='\e[1;36m'
YELLOW='\e[1;33m'
RESET='\e[0m'
BOLD='\e[1m'

echo -e "${CYAN}========================================${RESET}"
echo -e "${BOLD}${MAGENTA}       THC-OS SYSTEM INFORMATION        ${RESET}"
echo -e "${CYAN}========================================${RESET}"

OS_NAME=$(grep -E '^(NAME)=' /etc/os-release | cut -d '=' -f 2 | tr -d '"')
HOST=$(cat /etc/hostname)
KERNEL=$(uname -r)
ARCH=$(uname -m)
USER_NAME=$(whoami)
SHELL_PATH=$(echo $SHELL)

echo -e "${YELLOW} ► OS:${RESET}       ${OS_NAME}"
echo -e "${YELLOW} ► Hostname:${RESET} ${HOST}"
echo -e "${YELLOW} ► Kernel:${RESET}   ${KERNEL}"
echo -e "${YELLOW} ► Arch:${RESET}     ${ARCH}"
echo -e "${YELLOW} ► User:${RESET}     ${USER_NAME}"
echo -e "${YELLOW} ► Shell:${RESET}    ${SHELL_PATH}"
echo -e "${CYAN}========================================${RESET}"
